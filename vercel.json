{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), ambient-light-sensor=(), gyroscope=(), magnetometer=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.rjmpalavucentre.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://api.rjmpalavucentre.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets).*)",
      "destination": "/index.html"
    }
  ]
}
