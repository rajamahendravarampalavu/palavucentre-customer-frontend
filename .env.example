# Default to the same-origin API path. In local development, Vite proxies `/api`
# and `/uploads` to `http://localhost:4000`.
VITE_API_BASE_URL=/api

# If you need to bypass the dev proxy and hit the backend directly:
# VITE_API_BASE_URL=http://localhost:4000/api

# Google login for user account pages.
# Use your OAuth Web client ID from Google Cloud.
VITE_GOOGLE_CLIENT_ID=

# Optional: keep admin inside the main site at a custom path.
# VITE_ADMIN_BASE_PATH=/admin

# Optional: deploy the same admin UI as a standalone site like admin.palavucentre.
# When enabled, admin routes become /login and /dashboard instead of /admin/*.
# VITE_ADMIN_STANDALONE=true
# VITE_ADMIN_SITE_URL=https://admin.palavucentre.com/login
# VITE_PUBLIC_SITE_URL=https://palavucentre.com
# VITE_API_BASE_URL=https://palavucentre.com/api
